{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noEmit": true,
        "composite": false,
        "allowImportingTsExtensions": true,
        "isolatedModules": true
    },
    "references": [{ "path": "../shared-data" }],
    "include": ["src"]
}
